{
  "name": "sub2api-mobile",
  "version": "1.0.0",
  "main": "src/main.ts",
  "scripts": {
    "dev:h5": "uni -p h5",
    "build:h5": "uni build -p h5",
    "proxy": "node server/index.js",
    "dev:h5-proxy": "concurrently -n proxy,h5 -c green,blue \"npm run proxy\" \"npm run dev:h5\"",
    "dev:app": "uni -p app",
    "build:app": "npm run build:app:raw && node scripts/fix-app-runtime-version.cjs",
    "build:app:raw": "uni build -p app"
  },
  "dependencies": {
    "@dcloudio/uni-app": "3.0.0-alpha-1000920260626810",
    "@dcloudio/uni-components": "3.0.0-alpha-1000920260626810",
    "@dcloudio/uni-h5": "3.0.0-alpha-1000920260626810",
    "@dcloudio/uni-i18n": "3.0.0-alpha-1000920260626810",
    "@dcloudio/uni-shared": "3.0.0-alpha-1000920260626810",
    "@dcloudio/uni-ui": "^1.5.12",
    "@dcloudio/vite-plugin-uni": "3.0.0-alpha-1000920260626810",
    "@qiun/uni-ucharts": "^2.5.0-20230101",
    "@vue/shared": "3.5.35",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "vue": "3.5.35",
    "vue-router": "4.4.4"
  },
  "devDependencies": {
    "@dcloudio/types": "3.4.31",
    "@dcloudio/uni-app-plus": "3.0.0-alpha-1000920260626810",
    "@dcloudio/uni-app-uts": "3.0.0-alpha-1000920260626810",
    "@dcloudio/uni-cli-shared": "3.0.0-alpha-1000920260626810",
    "@dcloudio/uni-uts-v1": "3.0.0-alpha-1000920260626810",
    "@types/node": "^24.0.0",
    "concurrently": "^9.2.1",
    "sass": "^1.101.0",
    "typescript": "~5.9.2",
    "vite": "8.1.0"
  },
  "private": true
}
